DATABASE_URL=postgresql://swarm:swarm_dev@localhost:5433/swarm
REDIS_URL=redis://localhost:6379

# Cockpit-api binds here. Hook bridge POSTs back to ${COCKPIT_API_PUBLIC_HOST}/hooks/claude-code.
COCKPIT_API_PORT=4500
COCKPIT_API_PUBLIC_HOST=http://127.0.0.1:4500

# Comma-separated CORS origins for the cockpit frontend.
COCKPIT_CORS_ORIGIN=http://localhost:4400,http://127.0.0.1:4400
