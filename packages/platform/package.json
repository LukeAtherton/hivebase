{
  "name": "@swarm/platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "echo 'No build needed - running TypeScript directly with tsx'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@swarm/core": "workspace:*",
    "drizzle-orm": "^0.31.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
